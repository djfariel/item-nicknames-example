{
  "name": "item-nicknames-example",
  "version": "1.0.0",
  "title": "Item Nicknames: Example Pack",
  "author": "djfariel",
  "factorio_version": "2.1",
  "description": "Example search nicknames for vanilla and Space Age items, shipped through the Item Nicknames pack API.",
  "dependencies": [
    "base >= 2.1",
    "? space-age >= 2.1",
    "item-nicknames >= 1.0.0"
  ],
  "package": {
    "ignore": [
      ".git/**",
      ".gitignore",
      ".idea/**",
      ".vscode/**",
      ".editorconfig",
      "description.md",
      "faq.md",
      "gallery/**",
      "gallery/*.jpg",
      "gallery/*.jpeg",
      "**/*.zip",
      "Thumbs.db",
      ".DS_Store"
    ],
    "gallery": ["gallery/*.png"],
    "prune_gallery": true,
    "readme": "description.md",
    "faq": "faq.md",
    "sync_portal_details": true,
    "zipLocation": "outside"
  }
}
